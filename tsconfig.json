{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noImplicitAny": true,
    "sourceMap": false,
    "lib": ["ES2020", "DOM"]
  },
  "include": ["src/**/*.ts"]
}
